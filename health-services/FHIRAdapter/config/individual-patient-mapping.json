{
  "version": "1.0",
  "fhirResource": "Patient",
  "egovModel": "Individual",
  "egovService": "individual-service",

  "apiMapping": {
    "create": {
      "endpoint": "/health-individual/v1/_create",
      "method": "POST",
      "requestModel": "IndividualBulkRequest",
      "responseModel": "IndividualBulkResponse",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "update": {
      "endpoint": "/health-individual/v1/_update",
      "method": "POST",
      "requestModel": "IndividualBulkRequest",
      "responseModel": "IndividualBulkResponse",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "search": {
      "endpoint": "/health-individual/v1/_search",
      "method": "POST",
      "requestModel": "IndividualSearchRequest",
      "responseModel": "IndividualBulkResponse",
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "delete": {
      "endpoint": "/health-individual/v1/_delete",
      "method": "POST",
      "requestModel": "IndividualBulkRequest",
      "responseModel": "IndividualBulkResponse",
      "softDelete": true
    }
  },

  "requestModels": {
    "IndividualBulkRequest": {
      "basePath": "$.Individuals[*]",
      "isArray": true
    },
    "IndividualSearchRequest": {
      "basePath": "$.Individual",
      "isArray": false
    }
  },

  "responseModels": {
    "IndividualBulkResponse": {
      "basePath": "$.Individuals[*]",
      "isArray": true,
      "totalCountPath": "$.TotalCount"
    }
  },

  "fieldMappings": [
    {
      "fhirField": "id",
      "egovField": "id",
      "description": "FHIR logical ID (UUID)"
    },
    {
      "fhirField": "meta.lastUpdated",
      "egovField": "auditDetails.lastModifiedTime",
      "transform": "epochToIso"
    },
    {
      "fhirField": "meta.source",
      "egovField": "source",
      "transform": "prefixUri",
      "transformConfig": { "prefix": "urn:egov:source:" }
    },
    {
      "fhirField": "meta.tag[tenant]",
      "egovField": "tenantId",
      "transform": "toTag",
      "transformConfig": { "system": "urn:egov:tenant" }
    },
    {
      "fhirField": "active",
      "egovField": "isDeleted",
      "transform": "negate"
    },
    {
      "fhirField": "name[0].text",
      "egovField": "name.givenName",
      "transform": "concatName",
      "transformConfig": { "fields": ["name.givenName", "name.familyName", "name.otherNames"] }
    },
    {
      "fhirField": "name[0].given",
      "egovField": "name.givenName",
      "isArray": true
    },
    {
      "fhirField": "name[0].family",
      "egovField": "name.familyName"
    },
    {
      "fhirField": "birthDate",
      "egovField": "dateOfBirth",
      "transform": "epochToDate"
    },
    {
      "fhirField": "gender",
      "egovField": "gender",
      "transform": "codeMap",
      "transformConfig": {
        "toFhir": { "MALE": "male", "FEMALE": "female", "TRANSGENDER": "other", "OTHER": "other" },
        "toEgov": { "male": "MALE", "female": "FEMALE", "other": "OTHER", "unknown": "OTHER" }
      }
    },
    {
      "fhirField": "telecom[mobile]",
      "egovField": "mobileNumber",
      "transform": "toTelecom",
      "transformConfig": { "system": "phone", "use": "mobile" }
    },
    {
      "fhirField": "telecom[altPhone]",
      "egovField": "altContactNumber",
      "transform": "toTelecom",
      "transformConfig": { "system": "phone", "use": "home" }
    },
    {
      "fhirField": "telecom[email]",
      "egovField": "email",
      "transform": "toTelecom",
      "transformConfig": { "system": "email" }
    },
    {
      "fhirField": "photo[0]",
      "egovField": "photo",
      "transform": "toAttachment"
    },
    {
      "fhirField": "address",
      "egovField": "address",
      "isArray": true,
      "fieldMappings": [
        { "fhirField": "line[0]", "egovField": "addressLine1" },
        { "fhirField": "line[1]", "egovField": "addressLine2" },
        { "fhirField": "city", "egovField": "city" },
        { "fhirField": "district", "egovField": "district" },
        { "fhirField": "state", "egovField": "state" },
        { "fhirField": "postalCode", "egovField": "pincode" },
        { "fhirField": "country", "egovField": "country" },
        {
          "fhirField": "use",
          "egovField": "type",
          "transform": "codeMap",
          "transformConfig": {
            "toFhir": { "PERMANENT": "home", "CORRESPONDENCE": "work" },
            "toEgov": { "home": "PERMANENT", "work": "CORRESPONDENCE" }
          }
        }
      ]
    }
  ],

  "identifierMappings": [
    {
      "name": "egovIndividualId",
      "system": "urn:egov:individual",
      "egovField": "individualId",
      "use": "official",
      "isBusinessId": true
    },
    {
      "name": "abhaAddress",
      "system": "https://healthid.abdm.gov.in/abha-address",
      "egovField": "identifiers[?(@.identifierType=='ABHA_ADDRESS')].identifierId",
      "use": "official"
    },
    {
      "name": "abhaNumber",
      "system": "https://healthid.abdm.gov.in/abha-number",
      "egovField": "identifiers[?(@.identifierType=='ABHA_NUMBER')].identifierId",
      "use": "official",
      "privacy": { "mask": true, "pattern": "XX-XXXX-XXXX-{last4}" }
    },
    {
      "name": "aadhar",
      "system": "urn:uidai:aadhaar",
      "egovField": "identifiers[?(@.identifierType=='AADHAR')].identifierId",
      "privacy": { "mask": true, "pattern": "XXXX-XXXX-{last4}", "excludeFromResponse": true }
    },
    {
      "name": "pan",
      "system": "urn:incometax:pan",
      "egovField": "identifiers[?(@.identifierType=='PAN')].identifierId",
      "privacy": { "mask": true, "pattern": "{first3}XXXXX{last2}" }
    }
  ],

  "extensionMappings": [
    {
      "url": "https://digit.org/extensions/isDeleted",
      "egovField": "isDeleted",
      "valueType": "boolean"
    },
    {
      "url": "https://digit.org/extensions/audit/createdTime",
      "egovField": "auditDetails.createdTime",
      "valueType": "dateTime",
      "transform": "epochToIso"
    },
    {
      "url": "https://digit.org/extensions/audit/createdBy",
      "egovField": "auditDetails.createdBy",
      "valueType": "string"
    },
    {
      "url": "https://digit.org/extensions/audit/lastModifiedBy",
      "egovField": "auditDetails.lastModifiedBy",
      "valueType": "string"
    }
  ],

  "searchParamMappings": [
    {
      "fhirParam": "_id",
      "egovField": "id"
    },
    {
      "fhirParam": "identifier",
      "egovField": "individualId",
      "description": "When system not specified, searches individualId. With system, routes to appropriate identifier."
    },
    {
      "fhirParam": "name",
      "egovField": "name.givenName"
    },
    {
      "fhirParam": "family",
      "egovField": "name.familyName"
    },
    {
      "fhirParam": "given",
      "egovField": "name.givenName"
    },
    {
      "fhirParam": "birthdate",
      "egovField": "dateOfBirth",
      "transform": "dateToEpoch"
    },
    {
      "fhirParam": "gender",
      "egovField": "gender",
      "transform": "codeMap"
    },
    {
      "fhirParam": "phone",
      "egovField": "mobileNumber"
    },
    {
      "fhirParam": "email",
      "egovField": "email"
    },
    {
      "fhirParam": "address-city",
      "egovField": "address.city"
    },
    {
      "fhirParam": "address-state",
      "egovField": "address.state"
    },
    {
      "fhirParam": "address-postalcode",
      "egovField": "address.pincode"
    },
    {
      "fhirParam": "active",
      "egovField": "isDeleted",
      "transform": "negate"
    },
    {
      "fhirParam": "_tag",
      "egovField": "tenantId",
      "transformConfig": { "extractFromSystem": "urn:egov:tenant" }
    },
    {
      "fhirParam": "_count",
      "egovField": "limit"
    },
    {
      "fhirParam": "_offset",
      "egovField": "offset"
    }
  ]
}
